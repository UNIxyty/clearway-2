# EAD Basic – AIP download (/aip-test and scripts/ead-download-aip-pdf.mjs)
EAD_USER=your_ead_username
EAD_PASSWORD_ENC=base64_encoded_password

# Optional: AI extraction and GEN rewriting (scripts/ead-extract-aip-from-pdf-ai.mjs, aip-sync-server.mjs, /aip-test)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# See docs/OPENAI-MODELS-GEN.md for Gen 5 and other model IDs (e.g. gpt-5.4, gpt-5-mini, gpt-4.1).

# OpenRouter API key – required when using Anthropic or Google models (model ID contains "/")
# Used by aip-sync-server.mjs for both AIP extract and GEN rewrite when model is e.g. anthropic/claude-sonnet-4 or google/gemini-2.5-flash
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_GEN_MODEL=anthropic/claude-opus-4

# Supabase auth (portal login)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# NEXT_PUBLIC_SITE_URL=https://your-portal-domain.example

# Self-hosted storage roots
STORAGE_ROOT=/storage
CACHE_ROOT=/cache
NODE_ENV=production

# Internal sync service URLs (for Docker/Coolify network)
# NOTAM_SYNC_URL=http://notam-sync:3001
# WEATHER_SYNC_URL=http://weather-sync:3001
# AIP_SYNC_URL=http://aip-sync:3002
# NOTAM_SCRAPER=skylink

# Lithuania HITL noVNC test flow (optional overrides)
# LITHUANIA_SELENIUM_URL=http://lithuania-browser:4444/wd/hub
# LITHUANIA_NOVNC_URL=http://your-hostname:6080/?autoconnect=1&resize=scale

# SkyLink API (NOTAM + weather sync source)
# SKYLINK_API_KEY=your_rapidapi_key
# SKYLINK_API_HOST=skylink-api.p.rapidapi.com
# SKYLINK_API_BASE_URL=https://skylink-api.p.rapidapi.com

# Telegram debug bot (optional)
# Create a bot via @BotFather and set webhook to /api/telegram/debug
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_BOT_WEBHOOK_SECRET=long_random_secret
# TELEGRAM_DEBUG_ALLOWED_CHAT_IDS=123456789,-1001234567890
# Telegram bug reports (optional; defaults to TELEGRAM_BOT_TOKEN if TELEGRAM_BUG_BOT_TOKEN is not set)
# TELEGRAM_BUG_BOT_TOKEN=123456789:AA...
# TELEGRAM_BUG_BOT_WEBHOOK_SECRET=another_long_random_secret
# TELEGRAM_BUG_CHAT_ID=-1001234567890
# TELEGRAM_BUG_ALLOWED_CHAT_IDS=123456789,-1001234567890
