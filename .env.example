# EAD Basic – AIP download (/aip-test and scripts/ead-download-aip-pdf.mjs)
EAD_USER=your_ead_username
EAD_PASSWORD_ENC=base64_encoded_password

# Optional: AI extraction and GEN rewriting (scripts/ead-extract-aip-from-pdf-ai.mjs, aip-sync-server.mjs, /aip-test)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# See docs/OPENAI-MODELS-GEN.md for Gen 5 and other model IDs (e.g. gpt-5.4, gpt-5-mini, gpt-4.1).

# Optional: GEN rewriting with Claude via OpenRouter (scripts/gen-rewrite-claude-openrouter.mjs)
# Either set here or pass in the command: OPENROUTER_API_KEY=sk-or-v1-xxx node scripts/gen-rewrite-claude-openrouter.mjs EB
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_GEN_MODEL=anthropic/claude-sonnet-4
