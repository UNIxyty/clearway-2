{
  "name": "aip-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/embed-ead-icaos.mjs && next dev",
    "build": "node scripts/embed-ead-icaos.mjs && node scripts/copy-ead-icaos-to-public.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "notam": "node scripts/notam-scraper.mjs",
    "sync:notam": "node scripts/notam-sync-server.mjs",
    "sync:weather": "SYNC_SERVER_MODE=weather node scripts/notam-sync-server.mjs",
    "gen": "node scripts/ead-download-gen-pdf.mjs",
    "enr": "node scripts/ead-download-enr-pdf.mjs",
    "test:e2e": "node scripts/e2e-portal-test.mjs",
    "test:e2e:aip": "node scripts/e2e-aip-test.mjs",
    "test:e2e:aip-only": "node scripts/e2e-aip-only-test.mjs",
    "test:e2e:report": "node scripts/generate-test-report.mjs",
    "test:e2e:webhook:test": "node scripts/test-webhook.mjs",
    "test:e2e:webhook:send": "node scripts/send-test-webhook.mjs",
    "test:notam:skylink": "node scripts/test-skylink-notam.mjs",
    "check:sync-services": "node scripts/check-sync-services.mjs",
    "test:auth": "node --test tests/auth-email-flow-utils.test.mjs",
    "test:ai-prompts": "node --test tests/ai-prompts-english.test.mjs",
    "test:auth-and-prompts": "node --test tests/auth-email-flow-utils.test.mjs tests/ai-prompts-english.test.mjs",
    "test:ead:ad-names": "node scripts/ead-extract-ad-document-names.mjs",
    "ead:one-ad-per-country": "node scripts/ead-download-one-ad-per-country.mjs",
    "ead:dump-authorities": "node scripts/ead-download-one-ad-per-country.mjs --dump-authorities data/ead-aip-authority-prefixes-portal.json",
    "ead:one-ad-per-country:pending": "node scripts/ead-download-one-ad-per-country.mjs --only-pending",
    "ead:build-country-icao-db": "node scripts/ead-download-one-ad-per-country.mjs --build-icao-db-only --refresh-icao-db",
    "test:ead:ad-report": "node scripts/generate-ead-ad-report.mjs",
    "airports:import": "node scripts/import-ead-airports.mjs",
    "airports:import:dry": "node scripts/import-ead-airports.mjs --dry-run",
    "airports:import:all": "node scripts/import-ead-airports.mjs",
    "airports:import:all:dry": "node scripts/import-ead-airports.mjs --dry-run",
    "airports:russia:map": "node scripts/map-russia-international-names.mjs",
    "airports:russia:map:dry": "node scripts/map-russia-international-names.mjs --dry-run",
    "airports:dynamic:collect": "node scripts/tools/collect-all-packages.mjs --out data/dynamic-packages.json",
    "airports:dynamic:enrich": "node scripts/tools/enrich-airports.mjs --in data/dynamic-packages.json --out data/dynamic-airports.json",
    "airports:dynamic:upsert": "node scripts/tools/upsert-airports-to-supabase.mjs --in data/dynamic-airports.json",
    "airports:dynamic:refresh": "npm run airports:dynamic:collect && npm run airports:dynamic:enrich && npm run airports:dynamic:upsert",
    "airports:dynamic:refresh:dry": "npm run airports:dynamic:collect && npm run airports:dynamic:enrich && node scripts/tools/upsert-airports-to-supabase.mjs --in data/dynamic-airports.json --dry-run",
    "ead:web-aip:upsert": "node scripts/tools/upsert-ead-web-aip-links-to-supabase.mjs",
    "ead:web-aip:upsert:dry": "node scripts/tools/upsert-ead-web-aip-links-to-supabase.mjs --dry-run",
    "usa:aip:upload": "node scripts/upload-usa-aip-pdfs-to-s3.mjs",
    "usa:aip:upload:dry": "node scripts/upload-usa-aip-pdfs-to-s3.mjs --dry-run",
    "usa:airports:replace": "node scripts/tools/replace-usa-airports-in-supabase.mjs",
    "usa:airports:replace:dry": "node scripts/tools/replace-usa-airports-in-supabase.mjs --dry-run"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^14.2.18",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.49.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
